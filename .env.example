# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech:5432/database?sslmode=require

# JWT Secret (gere com: openssl rand -base64 32)
# IMPORTANTE: Mínimo 32 caracteres, nunca versionar esse valor!
JWT_SECRET=your_jwt_secret_here_min_32_characters_never_commit_this

# Email Service (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Hotmart Webhook (opcional)
HOTMART_WEBHOOK_SECRET=your_hotmart_webhook_secret

# Application URLs (Server-side only - NÃO use NEXT_PUBLIC_)
# Importante: sem barra final
APP_URL=https://www.focaaioficial.com
FRONTEND_URL=https://www.focaaioficial.com

# Node Environment (Vercel configura automaticamente em produção)
NODE_ENV=development

# Autenticação MFA Admin Panel
ADMIN_1_EMAIL=suporte1@exemplo.com
ADMIN_1_PHONE=5511999999999
ADMIN_2_EMAIL=suporte2@exemplo.com
ADMIN_2_PHONE=5511888888888
N8N_WEBHOOK_ADMIN_OTP=https://n8n.projetospalinos.online/webhook/admin-otp
